# ─────────────────────────────────────────
# FanHub MVP — Variables de Entorno
# Copia este archivo como .env.local y completa los valores
# ─────────────────────────────────────────

# DATABASE
# PostgreSQL connection string
# Ejemplo local: postgresql://postgres:password@localhost:5432/fanhub_mvp
# Ejemplo Supabase: postgresql://[user]:[password]@[host]:5432/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:password@localhost:5432/fanhub_mvp"

# NEXTAUTH
# Genera un secret seguro con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-aqui-cambia-esto-en-produccion"
# URL de la aplicación (sin trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# GOOGLE OAUTH
# Obtener en: https://console.cloud.google.com/apis/credentials
# Tipo: OAuth 2.0 Client ID (Web application)
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-google-client-secret"

# ─────────────────────────────────────────
# OPCIONAL — Para producción / features adicionales
# ─────────────────────────────────────────

# APPLE OAUTH (fase 2)
# APPLE_ID="your.app.id"
# APPLE_TEAM_ID="XXXXXXXXXX"
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
# APPLE_KEY_ID="XXXXXXXXXX"

# FILE STORAGE (para evidencias de verificación)
# Actualmente se usan URLs externas (Imgur, etc.)
# Para producción usar AWS S3 o Cloudflare R2:
# S3_BUCKET_NAME="fanhub-evidences"
# S3_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
# AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

# EMAIL (para reset de contraseña, notificaciones)
# EMAIL_SERVER="smtp://username:password@smtp.example.com:587"
# EMAIL_FROM="FanHub <noreply@fanhub.cl>"
